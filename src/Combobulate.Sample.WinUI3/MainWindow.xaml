<Window
    x:Class="Combobulate.Sample.WinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:c="using:Combobulate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Combobulate Sample (WinUI 3)">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Combobulate — OBJ quads via composition"
                   Style="{ThemeResource TitleTextBlockStyle}"/>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button x:Name="LoadObjButton"
                    Content="Load OBJ…"
                    Click="LoadObjButton_Click"/>
            <Button Content="Load book sample"
                    Click="LoadBook_Click"
                    ToolTipService.ToolTip="Loads samples/book.obj which references book.mtl with cover/pages textures."/>
            <Button Content="Reset cube" Click="ResetCube_Click"/>
            <Button Content="Reset rotation" Click="ResetRotation_Click"/>
            <ComboBox x:Name="MaterialModeBox"
                      SelectionChanged="MaterialModeBox_SelectionChanged"
                      ToolTipService.ToolTip="How materials are resolved (Auto, UseFallback, UseDiffuse).">
                <ComboBoxItem Content="Auto" IsSelected="True"/>
                <ComboBoxItem Content="UseFallback"/>
                <ComboBoxItem Content="UseDiffuse"/>
            </ComboBox>
            <ComboBox x:Name="SortAlgorithmBox"
                      SelectionChanged="SortAlgorithmBox_SelectionChanged"
                      ToolTipService.ToolTip="Painter-sort algorithm. Bsp (default) is cycle-free for any view; Newell handles arbitrary geometry with on-demand splits; Topological is the original O(n²) plane test that falls back to centroid-Z on cycles.">
                <ComboBoxItem Content="Bsp" IsSelected="True"/>
                <ComboBoxItem Content="Newell"/>
                <ComboBoxItem Content="Topological"/>
            </ComboBox>
            <ComboBox x:Name="RenderingModeBox"
                      SelectionChanged="RenderingModeBox_SelectionChanged"
                      ToolTipService.ToolTip="Rendering pipeline. SpritePainter (default): per-frame UI-thread sort, vulnerable to GPU/CPU clock drift. DualTreeAtomicSwap: predictive two-tree swap via opacity expression. BakedAspectGraph: pre-bake every constant-order interval at setup, drive opacity entirely from compositor expression — zero per-frame UI work, no drift possible by construction.">
                <ComboBoxItem Content="SpritePainter" IsSelected="True"/>
                <ComboBoxItem Content="DualTreeAtomicSwap"/>
                <ComboBoxItem Content="BakedAspectGraph"/>
            </ComboBox>
            <ToggleSwitch x:Name="ExternalRotationToggle"
                          OnContent="External (composition)"
                          OffContent="Internal (control DPs)"
                          Toggled="ExternalRotationToggle_Toggled"
                          ToolTipService.ToolTip="When ON, rotation sliders apply a Composition TransformMatrix to the controls' outer Visuals. The controls themselves stay at identity — so the SpriteVisual painter sort never re-runs, exposing back-face / paint-order artefacts as the model spins."/>
            <Button Content="Refresh quads"
                    Click="RefreshQuads_Click"
                    ToolTipService.ToolTip="External-mode helper. Re-runs back-face cull / painter sort (Combobulate) and re-bakes mesh (CombobulateSceneVisual) for the current slider rotation."/>
            <ToggleSwitch x:Name="AutoRefreshToggle"
                          OnContent="Auto-refresh"
                          OffContent="Manual refresh"
                          Toggled="AutoRefreshToggle_Toggled"
                          ToolTipService.ToolTip="Only meaningful in external rotation mode. When ON, subscribes to CompositionTarget.Rendering and feeds the live property-set value into RebuildForExternalRotation per UI tick — painter sort and back-face cull stay in sync as the model spins, no manual Refresh needed."/>
            <ToggleSwitch x:Name="SpinToggle"
                          OnContent="Spin"
                          OffContent="Static"
                          Toggled="SpinToggle_Toggled"
                          ToolTipService.ToolTip="Autonomous continuous Y-axis spin. Turns on External + Auto-refresh automatically and advances the shared rotation property set from the CompositionTarget.Rendering tick — one coherent yaw per frame, visible to both renderers' cull/sort via the same expression animation."/>
            <TextBlock Text="s/turn:" VerticalAlignment="Center" Margin="8,0,0,0"
                       ToolTipService.ToolTip="Spin period in seconds. Smaller = faster. Use to test whether the residual flicker scales with angular speed (clock-offset hypothesis predicts WORSE flicker as speed increases, since the same time offset becomes a bigger yaw delta)."/>
            <Slider x:Name="SpinSpeedSlider"
                    Minimum="0.5" Maximum="30" Value="6"
                    Width="200"
                    StepFrequency="0.1"
                    TickFrequency="5"
                    TickPlacement="Outside"
                    VerticalAlignment="Center"
                    ValueChanged="OnSpinSpeedChanged"/>
            <TextBlock x:Name="SpinSpeedValueText" Text="6.0" VerticalAlignment="Center" Width="40"/>
            <ToggleSwitch x:Name="ShowSceneVisualToggle"
                          OnContent="z-buffer panel ON"
                          OffContent="z-buffer panel off"
                          IsOn="False"
                          Toggled="ShowSceneVisualToggle_Toggled"
                          ToolTipService.ToolTip="Show the SceneVisual (z-buffer) reference panel beside the SpriteVisual painter-sort panel. Off by default; the SpriteVisual panel takes the full width when off."/>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       Text="Loaded: built-in cube"/>
        </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="SceneVisualColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="SpriteVisual (painter sort)"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.7" Margin="0,0,0,4"/>
            <TextBlock x:Name="SceneVisualLabel"
                       Grid.Column="1" Grid.Row="0"
                       Text="SceneVisual (z-buffer)"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.7" Margin="0,0,0,4"
                       Visibility="Collapsed"/>

            <c:Combobulate x:Name="combobulate"
                           Grid.Column="0" Grid.Row="1"
                           ModelScale="120"
                           Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                           BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           BorderThickness="1"/>

            <c:CombobulateSceneVisual x:Name="combobulateSceneVisual"
                             Grid.Column="1" Grid.Row="1"
                             ModelScale="{x:Bind combobulate.ModelScale, Mode=OneWay}"
                             RotationX="{x:Bind combobulate.RotationX, Mode=OneWay}"
                             RotationY="{x:Bind combobulate.RotationY, Mode=OneWay}"
                             RotationZ="{x:Bind combobulate.RotationZ, Mode=OneWay}"
                             PerspectiveDistance="{x:Bind combobulate.PerspectiveDistance, Mode=OneWay}"
                             Model="{x:Bind combobulate.Model, Mode=OneWay}"
                             Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                             BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                             BorderThickness="1"
                             Visibility="Collapsed"/>
        </Grid>

        <!--
            Thumbnail strip. Each thumbnail is a separate Combobulate control bound
            to the *same* ObjModel via x:Bind. ObjCache.ForModel uses a
            ConditionalWeakTable keyed on the model reference, so the heavy
            per-quad geometry build runs only once and is reused across all four
            controls — no re-parse, no re-prep when the main model changes.
        -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <c:Combobulate Width="96" Height="96" ModelScale="35"
                           RotationX="-25" RotationY="35" RotationZ="0"
                           Model="{x:Bind combobulate.Model, Mode=OneWay}"
                           Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                           BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           BorderThickness="1"/>
            <c:Combobulate Width="96" Height="96" ModelScale="35"
                           RotationX="20" RotationY="-30" RotationZ="0"
                           Model="{x:Bind combobulate.Model, Mode=OneWay}"
                           Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                           BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           BorderThickness="1"/>
            <c:Combobulate Width="96" Height="96" ModelScale="35"
                           RotationX="0" RotationY="60" RotationZ="15"
                           Model="{x:Bind combobulate.Model, Mode=OneWay}"
                           Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                           BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           BorderThickness="1"/>
            <!-- Source-driven thumbnail: stays on the cached "cube" key regardless of main view. -->
            <c:Combobulate Width="96" Height="96" ModelScale="35"
                           RotationX="-15" RotationY="-15" RotationZ="0"
                           Source="cube"
                           Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                           BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Spacing="4">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Pitch (X)" VerticalAlignment="Center"/>
                <Slider x:Name="PitchSlider"
                        Grid.Column="1"
                        Minimum="-180" Maximum="180"
                        ValueChanged="Rotation_ValueChanged"
                        StepFrequency="1"
                        TickFrequency="45" TickPlacement="Outside"/>

                <TextBlock Grid.Column="2" Text="Yaw (Y)" VerticalAlignment="Center"/>
                <Slider x:Name="YawSlider"
                        Grid.Column="3"
                        Minimum="-180" Maximum="180"
                        ValueChanged="Rotation_ValueChanged"
                        StepFrequency="1"
                        TickFrequency="45" TickPlacement="Outside"/>

                <TextBlock Grid.Column="4" Text="Roll (Z)" VerticalAlignment="Center"/>
                <Slider x:Name="RollSlider"
                        Grid.Column="5"
                        Minimum="-180" Maximum="180"
                        ValueChanged="Rotation_ValueChanged"
                        StepFrequency="1"
                        TickFrequency="45" TickPlacement="Outside"/>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Zoom" VerticalAlignment="Center"/>
                <Slider x:Name="ZoomSlider"
                        Grid.Column="1"
                        Minimum="10" Maximum="500"
                        Value="{x:Bind combobulate.ModelScale, Mode=TwoWay}"
                        StepFrequency="1"
                        TickFrequency="50" TickPlacement="Outside"/>

                <TextBlock Grid.Column="2" Text="Perspective" VerticalAlignment="Center"
                           ToolTipService.ToolTip="Focal distance in pixels. Smaller = stronger perspective (more visible side faces); larger = more orthographic. 0 ties the focal distance to the host width (legacy behavior — perspective changes with zoom)."/>
                <Slider x:Name="PerspectiveSlider"
                        Grid.Column="3"
                        Minimum="0" Maximum="2000"
                        Value="{x:Bind combobulate.PerspectiveDistance, Mode=TwoWay}"
                        StepFrequency="10"
                        TickFrequency="200" TickPlacement="Outside"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
